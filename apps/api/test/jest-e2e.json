{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@pitbook/db$": "<rootDir>/../../../packages/db/dist/index.js",
    "^@pitbook/db/(.*)$": "<rootDir>/../../../packages/db/dist/$1"
  },
  "modulePathIgnorePatterns": ["<rootDir>/../dist/"]
}
