{
  "name": "pitbook",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=@pitbook/api\" \"npm run dev --workspace=@pitbook/web\"",
    "build": "npm run generate --workspace=@pitbook/db && npm run build --workspaces",
    "test": "npm run test --workspace=@pitbook/api",
    "test:watch": "npm run test --workspace=@pitbook/api -- --watch",
    "test:coverage": "npm run test --workspace=@pitbook/api -- --coverage",
    "test:e2e": "npm run test --workspace=@pitbook/api -- test/",
    "db:generate": "npm run generate --workspace=@pitbook/db",
    "db:migrate": "npm run migrate --workspace=@pitbook/db",
    "db:push": "npm run push --workspace=@pitbook/db",
    "db:studio": "npm run studio --workspace=@pitbook/db",
    "db:seed": "npm run seed --workspace=@pitbook/db"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
